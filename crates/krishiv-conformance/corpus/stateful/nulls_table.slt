# NULL semantics over table state.

statement ok
CREATE TABLE n(v INT)

statement ok
INSERT INTO n VALUES (1), (NULL), (3)

query I
SELECT count(*) FROM n
----
3

query I
SELECT count(v) FROM n
----
2

query I
SELECT sum(v) FROM n
----
4

query I rowsort
SELECT v FROM n WHERE v IS NOT NULL
----
1
3

query I
SELECT v FROM n ORDER BY v NULLS FIRST LIMIT 1
----
NULL
